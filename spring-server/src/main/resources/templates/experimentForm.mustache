<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>새 실험</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-dark bg-dark px-3">
    <span class="navbar-brand">ML 실험 기록장</span>
    <a class="btn btn-outline-light btn-sm" href="/experiments">목록 보기</a>
</nav>

<div class="container mt-4" style="max-width:600px;">
    <h2 class="mb-3">새 ML 실험 만들기</h2>
    <form action="/experiments" method="post">
        <div class="mb-3">
            <label class="form-label">epochs</label>
            <input type="number" name="epochs" value="{{form.epochs}}" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">batchSize</label>
            <input type="number" name="batchSize" value="{{form.batchSize}}" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">learningRate (학습률)</label>
            <input type="number" step="0.001" name="learningRate" value="{{form.learningRate}}" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">메모</label>
            <input type="text" name="memo" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">태그</label>
            <input type="text" name="tag" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary">학습 실행</button>
        <a href="/experiments" class="btn btn-secondary">취소</a>
    </form>
</div>
</body>
</html>