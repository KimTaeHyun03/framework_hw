{{> layout/header}}

<div class="container mt-4">
    <h2 class="mb-3">실험 목록</h2>

    <table class="table table-hover align-middle">
        <thead class="table-light">
        <tr>
            <th>날짜/시간</th>
            <th>알고리즘</th>
            <th>정확도</th>
            <th>손실률</th>
            <th>메모/태그</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {{#experiments}}
        <tr>
            <td>{{createdAt}}</td>
            <td>{{algorithm}}</td>
            <td>{{accuracy}}</td>
            <td>{{loss}}</td>
            <td>{{memo}} {{#tag}}<span class="badge bg-secondary">{{tag}}</span>{{/tag}}</td>
            <td>
                <a class="btn btn-sm btn-outline-primary" href="/experiments/{{id}}">상세</a>
                <a class="btn btn-sm btn-outline-warning" href="/experiments/{{id}}/edit">수정</a>
                <form action="/experiments/{{id}}/delete" method="post" class="d-inline" style="margin:0">
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('정말 삭제하시겠습니까?')">삭제</button>
                </form>
            </td>
        </tr>
        {{/experiments}}
        {{^experiments}}
        <tr>
            <td colspan="6" class="text-center text-muted py-4">아직 기록된 실험이 없습니다.</td>
        </tr>
        {{/experiments}}
        </tbody>
    </table>
</div>

{{> layout/footer}}
