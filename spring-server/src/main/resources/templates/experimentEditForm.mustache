{{> layout/header}}

<div class="container mt-4" style="max-width:640px;">
    <h2 class="mb-3">실험 수정 <small class="text-muted">#{{experiment.id}}</small></h2>

    <div class="card mb-4">
        <div class="card-header">ML 결과 (수정 불가)</div>
        <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between"><span>알고리즘</span><span>{{experiment.algorithm}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>옵티마이저</span><span>{{experiment.optimizer}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>epochs</span><span>{{experiment.epochs}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>batchSize</span><span>{{experiment.batchSize}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>learningRate</span><span>{{experiment.learningRate}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>정확도</span><span>{{experiment.accuracy}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>손실률</span><span>{{experiment.loss}}</span></li>
            <li class="list-group-item d-flex justify-content-between"><span>생성 시각</span><span>{{experiment.createdAt}}</span></li>
        </ul>
    </div>

    <form action="/experiments/{{experiment.id}}" method="post">
        <div class="mb-3">
            <label class="form-label">메모</label>
            <input type="text" name="memo" value="{{experiment.memo}}" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">태그</label>
            <input type="text" name="tag" value="{{experiment.tag}}" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary">저장</button>
        <a href="/experiments/{{experiment.id}}" class="btn btn-secondary">취소</a>
    </form>
</div>

{{> layout/footer}}
